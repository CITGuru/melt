# ── Secrets ───────────────────────────────────────────────────────
# Anything that looks like an env file or credential. NEVER commit
# these — `examples/python/melt_demo.py` and `examples/rust` both
# read SNOWFLAKE_PASSWORD / JWT from env, and Snowflake JWTs are
# valid auth tokens with multi-month lifetimes.
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p8
*.p12
*.pfx
secrets/
**/private_key.*
*.local.toml
# Admin reload bearer tokens. `[metrics].admin_token_file` and
# `melt sync reload --token-file` both point at files like these.
admin.token
*.admin.token
admin_token
admin_token.txt

# ── Rust ──────────────────────────────────────────────────────────
target/
**/target/
**/*.rs.bk
*.pdb
# `Cargo.lock` is tracked at the workspace root (binary crates) but
# ignored under examples/rust because that's a standalone template.
examples/rust/Cargo.lock

# ── Python (examples/python) ──────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
.python-version

# Per-operator query variants for `router_demo.py`. The harness
# is generic (`--variants <path>` works on any directory of *.sql
# files), but any variants committed here would necessarily reference
# real table names / schemas from the operator's data warehouse.
# Operators keep their variants local; if a set becomes genuinely
# generic and shareable, drop it at a different path and update the
# demo's README pointer.
examples/python/variants/
!examples/python/variants/.gitkeep

examples/python/variants_hybrid/
!examples/python/variants_hybrid/.gitkeep

# ── Docker / Compose ──────────────────────────────────────────────
# Local-only overrides (convention from compose docs).
docker-compose.override.yml
docker-compose.*.local.yml
# Compose doesn't write state here, but operators sometimes mount
# named volumes onto bind mounts under ./data; keep that out.
data/
volumes/

# ── Editors / IDEs ────────────────────────────────────────────────
.idea/
.vscode/
.cursor/
*.swp
*.swo
*~

# ── OS junk ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Build & profiling artifacts ───────────────────────────────────
*.log
*.tmp
*.pid
flamegraph.svg
perf.data*
callgrind.out.*

# ── Coverage ──────────────────────────────────────────────────────
*.profraw
*.profdata
coverage/
lcov.info


/docs/internal/*
# KI-002 / POWA-92: KNOWN_ISSUES is the operator-visible punch list and
# the directory README documents this same exclude rule. Force-include
# past the `/docs/internal/*` blanket ignore. Git re-include rules need
# the directory itself to remain trackable, so we ignore directory
# contents (with the trailing `*`) rather than the directory. When you
# add a file under `docs/internal/`, add a matching `!` line here or it
# silently won't get tracked. See docs/internal/README.md.
!/docs/internal/KNOWN_ISSUES.md
!/docs/internal/README.md

# `melt sessions seed` writes the TPC-H sf=0.01 fixture here. ~6 MB,
# regenerable, never committed.
var/

# `melt sessions seed` also writes a generated demo config. Treat as
# regenerable scratch — operators with a real `melt.toml` keep it
# alongside.
melt.demo.toml

.claude/
.cursor/