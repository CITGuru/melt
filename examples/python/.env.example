# Copy to `.env` and fill in. The `.env` file is gitignored; NEVER
# commit one. Both python demos in this directory (`melt_demo.py`
# and `router_demo.py`) autoload `.env` via python-dotenv.

# Snowflake account identifier — e.g. "xy12345" or "<org>-<account>".
SNOWFLAKE_ACCOUNT=

# User the PAT / password belongs to. Snowflake PATs are already
# user-bound; this is echoed into the session context.
SNOWFLAKE_USER=

# Programmatic Access Token (PAT) or password. The demos pick up
# this value if it's set; otherwise they try to read `pat = "..."`
# from `melt.toml`.
SNOWFLAKE_PASSWORD=

# Optional session defaults. Omit if your queries use fully
# qualified table names and your account has a default warehouse.
# SNOWFLAKE_DATABASE=
# SNOWFLAKE_SCHEMA=
# SNOWFLAKE_WAREHOUSE=
# SNOWFLAKE_ROLE=

# Harness-specific knobs (router_demo.py only).
# REPEATS=1
# MAX_ROWS=50
