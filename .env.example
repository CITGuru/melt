# Template for `.env` — copy to `.env` and fill in real values.
# `.env` itself is gitignored. NEVER commit a real token here.
#
#   cp .env.example .env
#
# Both `examples/python/melt_demo.py` and `examples/rust` read these.

# Where the local Melt proxy listens (defaults match docker-compose).
MELT_HOST=127.0.0.1
MELT_PORT=8443
MELT_PROTOCOL=http

# Your Snowflake account locator + credentials. These get forwarded
# inside the login body — Melt never inspects the password / JWT.
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=

# Optional session defaults. Used by the demo scripts to resolve
# unqualified table names.
SNOWFLAKE_DATABASE=ANALYTICS
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_ROLE=
